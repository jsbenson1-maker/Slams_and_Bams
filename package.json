{
  "name": "analog-drum-machine",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "package": "vite build && electron-packager . PhyzixSnB --platform=win32 --arch=x64 --out=builds --overwrite",
    "installer": "node build-win-installer.js",
    "zip:win:portable": "node zip-win-portable.js",
    "dist-installer": "npm run installer && npm run zip:win:portable",
    "package:mac": "vite build && electron-packager . PhyzixSnB --platform=darwin --arch=x64,arm64 --out=builds --overwrite",
    "zip:mac": "node zip-macos.js",
    "dist-mac-local": "npm run package:mac && npm run zip:mac"
  },
  "dependencies": {
    "lucide-react": "^0.479.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "archiver": "^8.0.0",
    "electron": "^31.3.1",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
